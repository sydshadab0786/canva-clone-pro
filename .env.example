# ────────────────────────────────────────────────────────────────
# Canva Clone Pro — environment template. Copy to .env and fill in.
# ────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# ── API ──────────────────────────────────────────────────────────
API_PORT=4000
API_GLOBAL_PREFIX=api
API_CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql://ccp:ccp_password@localhost:5432/canva_clone_pro?schema=public

# ── Redis (cache, sessions, BullMQ) ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT / Auth ───────────────────────────────────────────────────
# Generate strong secrets, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_TTL=1209600       # 14 days (seconds)
AUTH_2FA_ISSUER=CanvaClonePro

# ── OAuth providers (optional in dev) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:4000/api/auth

# ── Email (magic link, verification) ─────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Canva Clone Pro <no-reply@canvaclone.pro>"

# ── Object storage (S3 / MinIO) ──────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ccp-media
S3_FORCE_PATH_STYLE=true

# ── Elasticsearch ────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200

# ── AI (optional — falls back to deterministic local generators) ──
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# ── Payments (optional — 'mock' activates subscriptions in-app) ───
BILLING_PROVIDER=mock          # mock | stripe | paypal | razorpay
BILLING_CURRENCY=usd
BILLING_CHECKOUT_BASE_URL=http://localhost:3000/dashboard/billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Deployment ───────────────────────────────────────────────────
APP_ORIGIN=http://localhost
GRAFANA_PASSWORD=admin

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Canva Clone Pro
